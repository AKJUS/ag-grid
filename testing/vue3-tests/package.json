{
  "name": "ag-grid-vue3-tests",
  "private": true,
  "version": "35.2.1-beta.20260331.1358",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "start-server": "vite preview > http.log 2>&1 & echo $! > pid",
    "stop-server": "kill $(cat pid) 2>/dev/null; rm -f pid",
    "playwright": "npx playwright test --reporter=list",
    "test:e2e": "run-s -c start-server playwright stop-server",
    "preview": "vite preview --host"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "ag-grid-community": "35.2.1-beta.20260331.1358",
    "ag-grid-enterprise": "35.2.1-beta.20260331.1358",
    "ag-grid-vue3": "35.2.1-beta.20260331.1358",
    "decimal.js": "^10.4.3"
  },
  "devDependencies": {
    "@mobileaction/action-kit": "^1.31.3",
    "playwright": "^1.56.0",
    "@playwright/test": "^1.56.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "~5.6.2",
    "vue-tsc": "^2.0.0",
    "npm-run-all": "^4.1.5"
  }
}
