{
  "name": "angular-package-tests",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "testing/angular-package-tests",
  "projectType": "",
  "targets": {
    "test:package": {
      "executor": "nx:noop",
      "inputs": [],
      "outputs": [],
      "dependsOn": [
        "test:package:local-18",
        "test:package:local-19",
        "test:package:local-20",
        "test:package:local-latest",
        "test:package:production-20"
      ],
      "configurations": {
        "update": {}
      }
    },
    "test:package:local-18": {
      "dependsOn": ["^pack"],
      "command": "{projectRoot}/runLegacy.sh 18",
      "configurations": {
        "update": {
          "command": "{projectRoot}/runLegacy.sh -u 18"
        }
      }
    },
    "test:package:local-19": {
      "dependsOn": ["^pack"],
      "command": "{projectRoot}/runLegacy.sh 19",
      "configurations": {
        "update": {
          "command": "{projectRoot}/runLegacy.sh -u 19"
        }
      }
    },
    "test:package:local-20": {
      "dependsOn": ["^pack"],
      "command": "{projectRoot}/run.sh 20",
      "configurations": {
        "update": {
          "command": "{projectRoot}/run.sh -u 20"
        }
      }
    },
    "test:package:production-20": {
      "dependsOn": ["^pack"],
      "command": "{projectRoot}/run.sh -p 20",
      "cache": false,
      "configurations": {
        "update": {
          "command": "{projectRoot}/run.sh -p -u 20"
        }
      }
    },
    "test:package:local-latest": {
      "dependsOn": ["^pack"],
      "command": "{projectRoot}/run.sh latest",
      "configurations": {
        "update": {
          "command": "{projectRoot}/run.sh -u latest"
        }
      }
    },
    "test:package:editor": {
      "dependsOn": ["^pack"],
      "command": "{projectRoot}/run.sh -n -e latest"
    }
  },
  "implicitDependencies": ["ag-grid-community", "ag-grid-enterprise", "ag-grid-angular"]
}
