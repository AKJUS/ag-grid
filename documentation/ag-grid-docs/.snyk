# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.1
# ignores vulnerabilities until expiry date; change duration by modifying expiry date
ignore:
    SNYK-JS-JPEGJS-2859218:
        - gif-frames@1.0.1 > get-pixels-frame-info-update@3.3.2 > jpeg-js@0.4.0:
              reason: >-
                  Used by gif-frames, and that is only run during build with gif images
                  that are in our control
              expires: 2026-06-08T00:00:00.000Z
              created: 2025-06-05T14:36:23.503Z
        - gif-frames@1.0.1 > save-pixels-jpeg-js-upgrade@2.3.4-jpeg-js-upgrade.0 > jpeg-js@0.4.0:
              reason: >-
                  Used by gif-frames, and that is only run during build with gif images
                  that are in our control
              expires: 2026-06-08T00:00:00.000Z
              created: 2025-06-05T14:36:23.503Z
    SNYK-JS-VITE-9653016:
        - vitest@2.1.9 > vite@5.4.11:
              reason: >-
                  Vitest is only used for development and we do not expose
                  the dev server to the network
              expires: 2026-06-08T00:00:00.000Z
              created: 2025-06-25T14:14:23.307Z
        - vitest@2.1.9 > vite-node@2.1.9 > vite@5.4.11:
              reason: >-
                  Vitest is only used for development and we do not expose
                  the dev server to the network
              expires: 2026-06-08T00:00:00.000Z
              created: 2025-06-25T14:14:23.307Z
    SNYK-JS-FORMDATA-10841150:
        - gif-frames@1.0.1 > get-pixels-frame-info-update@3.3.2 > request@2.88.2 > form-data@2.3.3:
              reason: >-
                  Gif frames is only used for building the website so form-data is not exposed outside
                  of development and CI
              expires: 2026-06-08T00:00:00.000Z
              created: 2025-07-22T10:35:00.007Z
    SNYK-JS-QS-14724253:
        - 'gif-frames@1.0.1 > get-pixels-frame-info-update@3.3.2 > request@2.88.2 > qs@6.5.3':
              reason: >-
                  qs is not used on the server
              expires: 2026-06-08T00:00:00.000Z
              created: 2025-01-05T10:10:00.000Z
    SNYK-JS-PREACT-14897824:
        - 'react-instantsearch@7.22.1 > instantsearch.js@4.86.1 > preact@10.27.2':
              reason: We don't use preact
              expires: 2026-06-08T00:00:00.000Z
              created: 2025-01-12T10:00:00.000Z
    SNYK-JS-AXIOS-15252993:
        - 'vite-plugin-mkcert@1.17.9 > axios@1.13.1':
              reason: >-
                  mkcert is only used during development - it's not used in the final production build
              expires: 2026-06-08T00:00:00.000Z
              created: 2026-02-12T10:10:00.000Z
patch: {}
