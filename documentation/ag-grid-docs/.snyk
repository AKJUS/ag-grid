# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.1
# ignores vulnerabilities until expiry date; change duration by modifying expiry date
ignore:
    SNYK-JS-JPEGJS-2859218:
        - gif-frames@1.0.1 > get-pixels-frame-info-update@3.3.2 > jpeg-js@0.3.7:
              reason: >-
                  Used by gif-frames, and that is only run during build with gif images
                  that are in our control
