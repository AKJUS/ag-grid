{
    // Default targets when running `rulesync generate` directly
    // Use `yarn setup-prompts` for dynamic detection of installed tools
    // Note: geminicli excluded due to TOML escaping bug with shell scripts in commands
    "targets": ["claudecode", "codexcli", "copilot", "cursor", "opencode", "antigravity"],
    "features": ["rules", "ignore", "mcp", "commands", "subagents"],
    "baseDirs": ["."],
    "delete": true,
    "verbose": false,
    "global": false,
    "simulateCommands": false,
    "simulateSubagents": false,
    "modularMcp": false,
}
